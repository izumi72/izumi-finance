# =============================================
#  DATABASE URL — pilih salah satu sesuai deploy
# =============================================

# --- Opsi 1: SQLite (development / lokal) ---
DATABASE_URL="file:./db/custom.db"

# --- Opsi 2: PostgreSQL (Vercel, Supabase, Neon, Railway) ---
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# --- Opsi 3: MySQL (PlanetScale, Railway) ---
# DATABASE_URL="mysql://user:password@host:3306/dbname"

# --- Opsi 4: Turso (libSQL) — perlu swap db.ts → db.turso.ts ---
# DATABASE_URL="libsql://nama-db-xxx.turso.io"
# TURSO_DATABASE_URL="libsql://nama-db-xxx.turso.io"
# TURSO_AUTH_TOKEN="token-dari-turso"

# =============================================
#  AUTH — WAJIB isi untuk production
# =============================================
NEXTAUTH_SECRET="ganti-ini-dengan-string-acak-yang-panjang"