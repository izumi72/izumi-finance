# ====== DATABASE ======
# Local development (SQLite) — already set, no need to change
DATABASE_URL="file:./db/custom.db"

# ====== AUTH ======
# JWT secret for login sessions — change this for production!
NEXTAUTH_SECRET="change-this-to-a-random-long-string"

# ====== TURSO (isi hanya saat deploy ke Vercel) ======
# Dapatkan dari: https://turso.tech → Database kamu → Settings
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""